{
  "name": "relback-theme",
  "version": "1.0.0",
  "description": "Tailwind CSS + DaisyUI theme for Relback",
  "private": true,
  "scripts": {
    "start": "tailwindcss --postcss -i ./src/styles.css -o ../static/css/dist/styles.css --watch",
    "build": "tailwindcss --postcss -i ./src/styles.css -o ../static/css/dist/styles.css --minify",
    "dev": "tailwindcss --postcss -i ./src/styles.css -o ../static/css/dist/styles.css"
  },
  "dependencies": {
    "daisyui": "^4.12.10"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  }
}
