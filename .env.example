# =============================================================================
#  relback — environment variables template
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Django core (required)
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-strong-random-50-char-string

# Comma-separated list of allowed hostnames / IPs
ALLOWED_HOSTS=localhost,127.0.0.1

# Gunicorn worker count (default: 3). Rule of thumb: 2 * CPU_COUNT + 1
GUNICORN_WORKERS=3

# ---------------------------------------------------------------------------
# Application database (Django models — users, clients, hosts, policies, etc.)
# Leave empty to use SQLite Demo Mode (no external DB required)
# ---------------------------------------------------------------------------
DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# ---------------------------------------------------------------------------
# Oracle RMAN Recovery Catalog (read-only)
# Leave empty to activate DemoRmanRepository (fake RMAN job data)
# ---------------------------------------------------------------------------
ORACLE_CATALOG_USER=
ORACLE_CATALOG_PASSWORD=
ORACLE_CATALOG_DSN=

# ---------------------------------------------------------------------------
# SLA Alerting (optional — for check_backup_sla management command)
# Leave empty: breaches are only logged (StubNotificationGateway).
# Set URL to POST JSON payload (e.g. Slack incoming webhook, PagerDuty, custom).
# ---------------------------------------------------------------------------
SLA_ALERT_WEBHOOK_URL=
